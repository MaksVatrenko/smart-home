{
  "name": "nuxt-app",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "nuxt build",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt build && nuxt preview",
    "postinstall": "nuxt prepare",
    "format": "prettier --write \"**/*.{js,ts,vue,json,scss,md}\"",
    "eslint": "eslint \"**/*.{js,ts,vue,cjs,mjs}\"",
    "eslint:fix": "eslint \"**/*.{js,ts,vue,cjs,mjs}\" --fix",
    "stylelint": "stylelint \"**/*.{css,scss,vue}\"",
    "stylelint:fix": "stylelint \"**/*.{css,scss,vue}\" --fix",
    "clean": "rm -rf .nuxt .output node_modules/.vite",
    "hard-clean": "rm -rf .nuxt .output node_modules",
    "analyze": "ANALYZE=true nuxt build",
    "build:analyze": "npm run clean && ANALYZE=true nuxt build"
  },
  "dependencies": {
    "@nuxt/eslint": "1.7.1",
    "@nuxt/fonts": "0.11.4",
    "@nuxt/icon": "1.15.0",
